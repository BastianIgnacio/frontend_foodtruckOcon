{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backendfoodtruckocon-production.up.railway.app/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://backendfoodtruckocon-production.up.railway.app/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
